# Copy to backend/.env. Never commit real keys.

FANAR_API_KEY=your_fanar_api_key_here
FANAR_ROUTER_MODEL=Fanar-C-1-8.7B
FANAR_RESPONDER_MODEL=Fanar-C-1-8.7B
FANAR_BACKUP_MODEL=Fanar-C-1-8.7B
FANAR_EXTRA_FALLBACK_MODELS=Fanar-S-1-7B
FANAR_ALLOW_BIG_MODELS=0
FANAR_ROUTER_TIMEOUT=6
FANAR_RESPONDER_TIMEOUT=14
QAARIB_USE_FANAR_ROUTER=0

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

# Google Calendar OAuth
# 1) Enable Google Calendar API in Google Cloud.
# 2) Create OAuth Client ID -> Desktop app.
# 3) Download JSON and save it as backend/google_credentials.json.
GOOGLE_CALENDAR_ENABLED=auto
GOOGLE_CALENDAR_CREDENTIALS=google_credentials.json
GOOGLE_CALENDAR_TOKEN=google_calendar_token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_SEND_UPDATES=none

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_JUDGE_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_ENABLED=1
GEMINI_FALLBACK_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_TIMEOUT=10

FANAR_EVAL_MODELS=Fanar,Fanar-C-1-8.7B,Fanar-C-2-27B
EVAL_TIME_LIMIT_MINUTES=60
